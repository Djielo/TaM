[Unit]
Description=TaM serveur local (HTML TAM -> API JSON / proxy)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/home/ubuntu
Environment=SERVE_TAM_BIND=0.0.0.0
ExecStart=/usr/bin/python3 /home/ubuntu/serve_tam.py
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
